# Создать requirements.txt (если нужны зависимости)
pip freeze > requirements.txt

# Создать модульные тесты
cat > test_app.py << EOF
import unittest
from app import greet

class TestGreeting(unittest.TestCase):
    def test_greet(self):
        self.assertEqual(greet("Alice"), "Hey there, Alice!")

if __name__ == '__main__':
    unittest.main()
EOF

# Запустить тесты
python test_app.py

# Добавить и закоммитить документацию и тесты
git add README.md requirements.txt test_app.py
git commit -m "docs: add README, requirements, and tests"
git push origin main

