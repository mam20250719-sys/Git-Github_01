# main.py
cat > main.py << 'EOF'
import json
import os

BOOKS_FILE = 'books.json'

def load_books():
    if os.path.exists(BOOKS_FILE):
        with open(BOOKS_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return []

def save_books(books):
    with open(BOOKS_FILE, 'w', encoding='utf-8') as f:
        json.dump(books, f, ensure_ascii=False, indent=2)

def add_book(title, author):
    books = load_books()
    # Проверка на дубликат
    if any(book['title'] == title and book['author'] == author for book in books):
        print(f"Книга '{title}' уже существует.")
        return
    books.append({'title': title, 'author': author})
    save_books(books)
    print(f"Книга '{title}' добавлена.")

def list_books():
    books = load_books()
    if not books:
        print("Книг нет.")
        return
    print("Список книг:")
    for i, book in enumerate(books, 1):
        print(f"{i}. {book['title']} — {book['author']}")

def get_stats():
    books = load_books()
    print(f"Всего книг: {len(books)}")
    authors = set(book['author'] for book in books)
    print(f"Уникальных авторов: {len(authors)}")

def delete_book(index):
    books = load_books()
    if 0 <= index < len(books):
        removed = books.pop(index)
        save_books(books)
        print(f"Книга '{removed['title']}' удалена.")
    else:
        print("Неверный номер книги.")

if __name__ == "__main__":
    add_book("1984", "Джордж Оруэлл")
    list_books()
    get_stats()
EOF

